<?xml version="1.0" encoding="UTF-8"?>
<configuration>
    <conversionRule conversionWord="clr" class="org.springframework.boot.logging.logback.ColorConverter"/>
    <conversionRule conversionWord="wex" class="org.springframework.boot.logging.logback.WhitespaceThrowableProxyConverter"/>
    <conversionRule conversionWord="wEx" class="org.springframework.boot.logging.logback.ExtendedWhitespaceThrowableProxyConverter"/>
    
    <!-- =============================================================================
         PII MASKING CONVERTER - GDPR Compliance
         ============================================================================= -->
    <!-- Masks email addresses, phone numbers, and credit cards in log messages -->
    <!-- Usage: %piiMsg (replaces %msg directly - NOT composite syntax) -->
    <conversionRule conversionWord="piiMsg" class="org.example.rentoza.config.logging.PiiMaskingConverter"/>
    
    <!-- =============================================================================
         Rentoza Application - Logback Configuration
         ============================================================================= -->

    <!-- Property for log pattern - clean and readable WITH PII MASKING -->
    <property name="LOG_PATTERN"
              value="%d{yyyy-MM-dd HH:mm:ss.SSS} [%thread] %-5level %logger{36} - %piiMsg%n"/>

    <!-- Property for colored console pattern (development) with correlation ID WITH PII MASKING -->
    <property name="CONSOLE_LOG_PATTERN"
              value="%clr(%d{HH:mm:ss.SSS}){faint} %clr([%X{correlationId:---------}]){blue} %clr(%-5level){highlight} %clr(%logger{36}){cyan} - %piiMsg%n"/>
    
    <!-- Property for SQL-specific pattern with visual markers WITH PII MASKING -->
    <property name="SQL_LOG_PATTERN"
              value="%clr(%d{HH:mm:ss.SSS}){faint} %clr([%X{correlationId:---------}]){blue} %clr([SQL]){green} - %piiMsg%n"/>

    <!-- =============================================================================
         CONSOLE APPENDER (Development & Production)
         ============================================================================= -->
    <appender name="CONSOLE" class="ch.qos.logback.core.ConsoleAppender">
        <encoder>
            <pattern>${CONSOLE_LOG_PATTERN}</pattern>
            <charset>UTF-8</charset>
        </encoder>
    </appender>

    <!-- =============================================================================
         SQL CONSOLE APPENDER (Development - Enhanced SQL Logging)
         ============================================================================= -->
    <appender name="SQL_CONSOLE" class="ch.qos.logback.core.ConsoleAppender">
        <encoder>
            <pattern>${SQL_LOG_PATTERN}</pattern>
            <charset>UTF-8</charset>
        </encoder>
        <!-- Only show SQL logs, filter out other messages -->
        <filter class="ch.qos.logback.classic.filter.ThresholdFilter">
            <level>DEBUG</level>
        </filter>
    </appender>

    <!-- =============================================================================
         ASYNC APPENDERS (Better Performance for Production)
         ============================================================================= -->
    <appender name="ASYNC_CONSOLE" class="ch.qos.logback.classic.AsyncAppender">
        <queueSize>512</queueSize>
        <discardingThreshold>0</discardingThreshold>
        <appender-ref ref="CONSOLE"/>
    </appender>

    <!-- =============================================================================
         JSON APPENDER FOR CLOUD RUN (Production - GCP Structured Logging)
         ============================================================================= -->
    <!-- Uses custom JsonLogLayout for Google Cloud Logging integration -->
    <appender name="JSON_CONSOLE" class="ch.qos.logback.core.ConsoleAppender">
        <layout class="org.example.rentoza.config.logging.JsonLogLayout">
            <serviceName>rentoza-backend</serviceName>
            <serviceVersion>${SERVICE_VERSION:-1.0.0}</serviceVersion>
        </layout>
    </appender>
    
    <appender name="ASYNC_JSON_CONSOLE" class="ch.qos.logback.classic.AsyncAppender">
        <queueSize>1024</queueSize>
        <discardingThreshold>0</discardingThreshold>
        <includeCallerData>true</includeCallerData>
        <appender-ref ref="JSON_CONSOLE"/>
    </appender>

    <!-- =============================================================================
         DEVELOPMENT PROFILE CONFIGURATION
         ============================================================================= -->
    <springProfile name="dev">
        <!-- Rentoza Application - INFO level shows key business events -->
        <logger name="org.example.rentoza" level="INFO" additivity="false">
            <appender-ref ref="CONSOLE"/>
        </logger>

        <!-- Spring Framework - WARN to reduce noise, ERROR for critical issues -->
        <logger name="org.springframework" level="WARN"/>
        <logger name="org.springframework.web" level="INFO"/>
        <logger name="org.springframework.security" level="WARN"/>
        <logger name="org.springframework.boot" level="INFO"/>

        <!-- Hibernate/JPA - Enhanced SQL logging with custom formatting -->
        <logger name="org.hibernate" level="WARN"/>
        <logger name="org.hibernate.SQL" level="${SQL_DEBUG_LEVEL:-WARN}" additivity="false">
            <appender-ref ref="SQL_CONSOLE"/>
        </logger>
        <logger name="org.hibernate.type.descriptor.sql.BasicBinder" level="${SQL_DEBUG_LEVEL:-WARN}" additivity="false">
            <appender-ref ref="SQL_CONSOLE"/>
        </logger>
        <logger name="org.hibernate.orm.jdbc.bind" level="${SQL_DEBUG_LEVEL:-WARN}" additivity="false">
            <appender-ref ref="SQL_CONSOLE"/>
        </logger>
        <logger name="org.hibernate.type" level="WARN"/>
        <logger name="org.hibernate.stat" level="INFO"/> <!-- For SQL execution statistics -->

        <!-- HikariCP Connection Pool - INFO for pool events only, WARN for internal pool stats -->
        <logger name="com.zaxxer.hikari" level="INFO"/>
        <logger name="com.zaxxer.hikari.pool" level="WARN"/> <!-- Suppress verbose connection creation logs -->

        <!-- WebSocket - WARN to reduce noise -->
        <logger name="org.springframework.messaging" level="WARN"/>
        <logger name="org.springframework.web.socket" level="WARN"/>

        <!-- Mail - INFO to see email sending summaries -->
        <logger name="org.springframework.mail" level="INFO"/>

        <!-- Thymeleaf - WARN to reduce template processing noise -->
        <logger name="org.thymeleaf" level="WARN"/>

        <!-- Root logger -->
        <root level="INFO">
            <appender-ref ref="CONSOLE"/>
        </root>
    </springProfile>

    <!-- =============================================================================
         PRODUCTION PROFILE CONFIGURATION
         ============================================================================= -->
    <springProfile name="prod">
        <!-- Rentoza Application - INFO for business-critical events only -->
        <!-- Uses JSON structured logging for Google Cloud Logging integration -->
        <logger name="org.example.rentoza" level="INFO" additivity="false">
            <appender-ref ref="ASYNC_JSON_CONSOLE"/>
        </logger>

        <!-- Spring Framework - WARN or ERROR only -->
        <logger name="org.springframework" level="WARN"/>
        <logger name="org.springframework.web" level="WARN"/>
        <logger name="org.springframework.security" level="WARN"/>
        <logger name="org.springframework.boot" level="WARN"/>

        <!-- Hibernate/JPA - WARN or ERROR only (no SQL in production) -->
        <logger name="org.hibernate" level="WARN"/>
        <logger name="org.hibernate.SQL" level="WARN"/>
        <logger name="org.hibernate.type" level="WARN"/>

        <!-- HikariCP Connection Pool - WARN for connection issues -->
        <logger name="com.zaxxer.hikari" level="WARN"/>

        <!-- WebSocket - WARN only -->
        <logger name="org.springframework.messaging" level="WARN"/>
        <logger name="org.springframework.web.socket" level="WARN"/>

        <!-- Mail - INFO to see email sending events -->
        <logger name="org.springframework.mail" level="INFO"/>

        <!-- Thymeleaf - WARN only -->
        <logger name="org.thymeleaf" level="WARN"/>

        <!-- External libraries - ERROR only -->
        <logger name="org.postgresql" level="ERROR"/>
        <logger name="org.apache" level="ERROR"/>

        <!-- Root logger - WARN to catch unexpected issues -->
        <!-- JSON Console for Cloud Run - structured logging for GCP -->
        <root level="WARN">
            <appender-ref ref="ASYNC_JSON_CONSOLE"/>
        </root>
    </springProfile>

    <!-- =============================================================================
         SPECIAL LOGGERS (All Profiles)
         ============================================================================= -->

    <!-- SQL Debug Toggle - Enable with app.debug.sql=true -->
    <!-- Set SQL_DEBUG_LEVEL=DEBUG in environment or application properties -->

    <!-- Silence noisy libraries -->
    <logger name="org.hibernate.jpa.internal.util.LogHelper" level="WARN"/>
    <logger name="org.hibernate.engine.jdbc.spi.SqlExceptionHelper" level="ERROR"/>
    <!-- Suppress Tomcat/Catalina startup noise -->
    <logger name="org.apache.catalina.startup.DigesterFactory" level="ERROR"/>
    <logger name="org.apache.catalina.util.LifecycleBase" level="ERROR"/>
    <logger name="org.apache.coyote.http11.Http11NioProtocol" level="ERROR"/> <!-- ProtocolHandler init noise -->
    <logger name="org.apache.tomcat.util.net.NioSelectorPool" level="ERROR"/> <!-- Reduced from WARN -->

    <!-- Firebase - INFO for push notification events -->
    <logger name="com.google.firebase" level="INFO"/>

    <!-- Commons Logging - Redirect to SLF4J -->
    <logger name="org.apache.commons.logging" level="WARN"/>
    
    <!-- Suppress verbose initialization logs -->
    <logger name="org.springframework.web.servlet.DispatcherServlet" level="WARN"/> <!-- Reduce init verbosity -->
    <logger name="org.springframework.web.servlet.mvc.method.annotation.RequestMappingHandlerMapping" level="WARN"/>

</configuration>
