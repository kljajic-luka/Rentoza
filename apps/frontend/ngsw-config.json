{
  "$schema": "./node_modules/@angular/service-worker/config/schema.json",
  "index": "/index.html",
  "assetGroups": [
    {
      "name": "app",
      "installMode": "prefetch",
      "resources": {
        "files": ["/favicon.ico", "/index.html", "/*.css", "/*.js"]
      }
    },
    {
      "name": "assets",
      "installMode": "lazy",
      "updateMode": "prefetch",
      "resources": {
        "files": ["/assets/**", "/*.(svg|cur|jpg|jpeg|png|apng|webp|avif|gif|otf|ttf|woff|woff2)"]
      }
    }
  ],
  "dataGroups": [
    {
      "name": "google-fonts-stylesheets",
      "urls": ["https://fonts.googleapis.com/css2?**", "https://fonts.googleapis.com/icon?**"],
      "cacheConfig": {
        "strategy": "performance",
        "maxSize": 10,
        "maxAge": "7d",
        "timeout": "3s"
      }
    },
    {
      "name": "google-fonts-webfonts",
      "urls": ["https://fonts.gstatic.com/**"],
      "cacheConfig": {
        "strategy": "performance",
        "maxSize": 30,
        "maxAge": "365d"
      }
    },
    {
      "name": "api-checkin-status",
      "urls": ["/api/bookings/*/check-in/status"],
      "cacheConfig": {
        "strategy": "freshness",
        "maxSize": 20,
        "maxAge": "5m",
        "timeout": "5s"
      }
    },
    {
      "name": "api-checkin-photos",
      "urls": ["/api/bookings/*/check-in/host/photos", "/api/bookings/*/check-in/photos/*"],
      "cacheConfig": {
        "strategy": "freshness",
        "maxSize": 100,
        "maxAge": "30m",
        "timeout": "10s"
      }
    },
    {
      "name": "api-cars-fresh",
      "urls": ["/api/cars/search", "/api/cars/*/availability"],
      "cacheConfig": {
        "strategy": "freshness",
        "maxSize": 50,
        "maxAge": "5m",
        "timeout": "3s"
      }
    },
    {
      "name": "api-cars-performance",
      "urls": ["/api/cars", "/api/cars/*"],
      "cacheConfig": {
        "strategy": "performance",
        "maxSize": 100,
        "maxAge": "1h"
      }
    },
    {
      "name": "api-static-data",
      "urls": ["/api/cars/makes", "/api/cars/features"],
      "cacheConfig": {
        "strategy": "performance",
        "maxSize": 10,
        "maxAge": "24h"
      }
    },
    {
      "name": "api-reviews",
      "urls": ["/api/reviews/**"],
      "cacheConfig": {
        "strategy": "freshness",
        "maxSize": 50,
        "maxAge": "10m",
        "timeout": "3s"
      }
    }
  ],
  "navigationUrls": ["/**", "!/**/*.*", "!/**/*__*", "!/**/*__*/**"]
}
