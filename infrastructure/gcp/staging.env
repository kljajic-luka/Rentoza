# Canonical staging deploy values
CHECKIN_WINDOW_HOURS_BEFORE_TRIP=2
CHECKIN_MAX_EARLY_HOURS=2
CHECKIN_TIMING_VALIDATION_ENABLED=true
CHECKIN_SCHEDULER_ENABLED=true
CHECKIN_NO_SHOW_MINUTES_AFTER_TRIP_START=120
CHECKIN_SCHEDULER_WINDOW_CRON='0 0/15 * * * *'
CHECKIN_SCHEDULER_NOSHOW_CRON='0 0/10 * * * *'
CHECKIN_SCHEDULER_NOSHOW_DIAGNOSTICS_ENABLED=false
CHECKOUT_SCHEDULER_ENABLED=true
CHECKOUT_WINDOW_HOURS_BEFORE_TRIP=1
CHECKOUT_LATE_GRACE_MINUTES=60
NOTIFICATIONS_EMAIL_ENABLED=true
MAIL_FROM=rentozzza@gmail.com
OAUTH2_REDIRECT_ALLOWED_URIS=https://rentoza.rs/auth/supabase/google/callback,https://www.rentoza.rs/auth/supabase/google/callback
PAYMENT_PROVIDER=MOCK
APP_ID_VERIFICATION_PROVIDER=MOCK
APP_PAYMENT_ENFORCE_REAL_PROVIDER=false

# Frontend URL for transactional email links (password reset, verification)
APP_FRONTEND_URL=https://rentoza.rs

# Consent policy metadata required by SecurityConfigValidator when prod profile is active.
# Update hash whenever legal terms/privacy content changes.
CONSENT_POLICY_VERSION=2025-01-01-v1
CONSENT_POLICY_HASH=18a6a549bed7639de02c30b3fc4c8686ec69260c00441f963a474bfeec2280ca

# Chat service runtime (non-secret)
CHAT_CORS_ALLOWED_ORIGINS=https://rentoza.rs,https://www.rentoza.rs
CHAT_WEBSOCKET_ALLOWED_ORIGINS=https://rentoza.rs,https://www.rentoza.rs
CHAT_STORAGE_PROVIDER=supabase
CHAT_STORAGE_BUCKET=chat-attachments
CHAT_REDIS_ENABLED=false
CHAT_RABBITMQ_ENABLED=false

# Chat Cloud Run sizing
CHAT_MEMORY=1Gi
CHAT_CPU=1
CHAT_MIN_INSTANCES=1
CHAT_MAX_INSTANCES=5
CHAT_CONCURRENCY=100

# Backend Cloud Run sizing
BACKEND_MEMORY=1Gi
BACKEND_CPU=1
BACKEND_MIN_INSTANCES=1
BACKEND_MAX_INSTANCES=5
BACKEND_TIMEOUT=300
# Rental agreement enforcement — requires both parties to accept before trip start
APP_COMPLIANCE_RENTAL_AGREEMENT_CHECKIN_ENFORCED=true
